<br><span class="line"> myBool  <span class="keyword">bool</span>    <span class="comment">// 1 byte</span></span><br><span class="line"> myInt   <span class="keyword">int32</span>   <span class="comment">// 4 bytes</span></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">b := myStructOptimized&#123;&#125;</span><br><span class="line">fmt.Println(unsafe.Sizeof(b)) <span class="comment">// ordered 16 bytes</span></span><br></pre></td></tr></table></figure><p><img alt="eed80975.png" src="/2018/10/29/语言相关/go/go-struct-memory/eed80975.png" width="" height=""></p>]]></content>
    
